# ===========================================
# Git Ignore
# ===========================================

# Environment files (IMPORTANT: Never commit .env)
.env
*.env.local
*.env.production

# Certbot certificates (server only)
infra/certbot/conf/
infra/certbot/www/
infra/certbot/logs/

# IDE
.idea/
**/.idea/
*.iml
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Build outputs
build/
target/
dist/
out/

# Dependencies
node_modules/

# Temporary files
tmp/
temp/
*.tmp

#claude
.claude
